---
import Layout from '../layouts/Layout.astro'
import LinksList from '../components/LinksList.astro'
import { getAllTools, getArticles, getSidebarItems } from '../lib/tools.js'

const tools = getAllTools()
const articles = getArticles()
const originalTools = getSidebarItems(tools).map(item => item.name)
const recentTools = [...tools]
    .filter(t => t.last_updated)
    .sort((a, b) => new Date(b.last_updated) - new Date(a.last_updated))
    .slice(0, 5)

function formatDate(d) {
    return d instanceof Date ? d.toISOString().slice(0, 10) : String(d)
}
---

<Layout>
    <header class="page-header">
        <h1>altbox.dev — A catalog of {tools.length} alternative power tools for the Linux/Unix/macOS command line</h1>
    </header>

    <p>
        The standard Unix tools have lasted us for decades. Every programmer should know them, but there are plenty of
        tools that add on to the standard tools. For example, <code>grep</code> works fine for finding text, but tools
        like <a href="/tool/ack">ack</a> and <a href="/tool/ripgrep">ripgrep</a> are designed for today's modern
        programmer working with large trees of heterogeneous source code.
    </p>

    <p>
        Find alternatives to {
            originalTools.map((tool, i) => (
                <><a href={`/alternative-to/${tool}`}>{tool}</a>{i < originalTools.length - 1 && (i === originalTools.length - 2 ? ' and ' : ', ')}</>
            ))
        }.
    </p>

    <h2>Recently added/updated</h2>

    <table class="recently-updated">
        <thead>
            <tr>
                <th>Tool</th>
                <th>Description</th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody>
            {recentTools.map(tool => (
                <tr>
                    <td>
                        <a href={`/tool/${tool.name}`}>{tool.name}</a>
                    </td>
                    <td>
                        {tool.description}
                        {(tool.language || tool.alternativeto.length > 0 || tool.workswith.length > 0) && (
                            <div class="badges">
                                {tool.alternativeto.map(a => (
                                    <a class="badge" href={`/alternative-to/${a}`}>Alternative to {a}</a>
                                ))}
                                {tool.language && <a class="badge" href={`/language/${tool.language.toLowerCase()}`}>{tool.language}</a>}
                                {tool.workswith.map(w => (
                                    <a class="badge" href={`/works-with/${w}`}>Works with {w}</a>
                                ))}
                            </div>
                        )}
                    </td>
                    <td>
                        <time datetime={formatDate(tool.last_updated)}>{formatDate(tool.last_updated)}</time>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>

    <LinksList links={articles} title="Related links" />

    <h2>Feedback</h2>

    <p>If you've got comments or feedback, email Andy Lester at <a href="mailto:andy@petdance.com">andy@petdance.com</a>.</p>

    <h2>Additions and errata</h2>

    <p>If you have a favorite tool that isn't here, please email Andy or submit an
    issue on our GitHub page:
    <a href="https://github.com/petdance/altbox" target="_blank" rel="noopener noreferrer">https://github.com/petdance/altbox</a></p>

</Layout>
