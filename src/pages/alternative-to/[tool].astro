---
import Layout from '../../layouts/Layout.astro'
import LinksList from '../../components/LinksList.astro'
import { getAllTools, getLinksForTool } from '../../lib/tools.js'

function formatDate(d) {
    return d instanceof Date ? d.toISOString().slice(0, 10) : String(d)
}

export function getStaticPaths() {
    const tools = getAllTools()
    const slugs = [...new Set(tools.flatMap(t => t.alternativeto))]
    return slugs.map(slug => ({
        params: { tool: slug },
        props: { slug, tools: tools.filter(t => t.alternativeto.includes(slug)) },
    }))
}

const { slug, tools } = Astro.props
const links = getLinksForTool(slug)
const description = `${tools.length} alternative${tools.length === 1 ? '' : 's'} to ${slug} for the command line.`
const canonical = `https://altbox.dev/alternative-to/${slug}/`
const schema = {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: `${slug} alternatives`,
    description,
    itemListElement: tools.map((tool, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        item: {
            '@type': 'SoftwareApplication',
            name: tool.name,
            description: tool.description,
            url: `https://altbox.dev/tool/${tool.name}/`,
        },
    })),
}
---

<Layout title={`${slug} alternatives`} description={description} canonical={canonical} schema={schema}>
    <header class="page-header">
        <h1>{tools.length} <code>{slug}</code> alternatives</h1>
    </header>

    <table class="recently-updated">
        <thead>
            <tr>
                <th>Tool</th>
                <th>Description</th>
                <th>Updated</th>
            </tr>
        </thead>
        <tbody>
            {tools.map(tool => (
                <tr>
                    <td>
                        <a href={`/tool/${tool.name.toLowerCase()}`}>{tool.name}</a>
                    </td>
                    <td>
                        {tool.description}
                        {(tool.language || tool.workswith.length > 0) && (
                            <div class="badges">
                                {tool.language && <a class="badge" href={`/language/${tool.language.toLowerCase()}`}>{tool.language}</a>}
                                {tool.workswith.map(w => (
                                    <a class="badge" href={`/works-with/${w}`}>Works with {w}</a>
                                ))}
                            </div>
                        )}
                    </td>
                    <td>
                        {tool.last_updated && <time datetime={formatDate(tool.last_updated)}>{formatDate(tool.last_updated)}</time>}
                    </td>
                </tr>
            ))}
        </tbody>
    </table>

    <LinksList links={links} />
</Layout>
