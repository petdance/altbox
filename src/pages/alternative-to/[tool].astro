---
import Layout from '../../layouts/Layout.astro'
import LinksList from '../../components/LinksList.astro'
import { getAllTools, getLinksForTool } from '../../lib/tools.js'

export function getStaticPaths() {
    const tools = getAllTools()
    const slugs = [...new Set(tools.flatMap(t => t.alternativeto))]
    return slugs.map(slug => ({
        params: { tool: slug },
        props: { slug, tools: tools.filter(t => t.alternativeto.includes(slug)) },
    }))
}

const { slug, tools } = Astro.props
const links = getLinksForTool(slug)
---

<Layout title={`Alternatives to the ${slug} command`}>
    <div class="page-header">
        <h1><code>{slug}</code> alternatives</h1>
    </div>

    <div class="tools-table">
        {tools.map(tool => (
            <div class="tool-card">
                <div class="tool-name">
                    <a href={`/tool/${tool.name.toLowerCase()}`}>{tool.name}</a>
                </div>
                <div class="tool-info">
                    <p class="description">{tool.description}</p>
                    <div class="badges">
                        {tool.language && <a class="badge" href={`/language/${tool.language.toLowerCase()}`}>{tool.language}</a>}
                        {tool.workswith.map(w => (
                            <a class="badge" href={`/works-with/${w}`}>Works with {w}</a>
                        ))}
                    </div>
                </div>
            </div>
        ))}
    </div>

    <style>
        .tools-table {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 1rem 2rem;
            margin: 2rem 0;
        }

        .tool-card {
            display: contents;
        }

        .tool-name {
            font-weight: bold;
        }

        .tool-name a {
            text-decoration: none;
            font-size: 1.1rem;
            font-family: var(--font-mono);
        }

        .tool-name a:hover {
            text-decoration: underline;
        }

        .tool-info .description {
            margin: 0 0 0.5rem 0;
            color: var(--muted);
            font-size: 0.9rem;
        }
    </style>

    <LinksList links={links} />
</Layout>
