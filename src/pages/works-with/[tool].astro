---
import Layout from '../../layouts/Layout.astro'
import { getAllTools } from '../../lib/tools.js'

export function getStaticPaths() {
    const tools = getAllTools()
    const slugs = [...new Set(tools.flatMap(t => t.workswith))]
    return slugs.map(slug => ({
        params: { tool: slug.toLowerCase() },
        props: { slug, tools: tools.filter(t => t.workswith.includes(slug)) },
    }))
}

const { slug, tools } = Astro.props
---

<Layout title={`CLI tools that work with ${slug}`}>
    <header class="page-header">
        <h1>Tools that work with <code>{slug}</code></h1>
    </header>

    <div class="tools-table">
        {tools.map(tool => (
            <div class="tool-card">
                <div class="tool-name">
                    <a href={`/tool/${tool.name.toLowerCase()}`}>{tool.name}</a>
                </div>
                <div class="tool-info">
                    <p class="description">{tool.description}</p>
                    <div class="badges">
                        {tool.alternativeto.map(alt => (
                            <a class="badge" href={`/alternative-to/${alt}`}>Alternative to {alt}</a>
                        ))}
                        {tool.language && <a class="badge" href={`/language/${tool.language.toLowerCase()}`}>{tool.language}</a>}
                    </div>
                </div>
            </div>
        ))}
    </div>

    <style>
        .tools-table {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 1rem 2rem;
            margin: 2rem 0;
        }

        .tool-card {
            display: contents;
        }

        .tool-name {
            font-weight: bold;
        }

        .tool-name a {
            text-decoration: none;
            font-size: 1.1rem;
            font-family: var(--font-mono);
        }

        .tool-name a:hover {
            text-decoration: underline;
        }

        .tool-info .description {
            margin: 0 0 0.5rem 0;
            color: var(--muted);
            font-size: 0.9rem;
        }
    </style>
</Layout>
