---
import Layout from '../../layouts/Layout.astro'
import { getAllTools } from '../../lib/tools.js'

export function getStaticPaths() {
    const tools = getAllTools()
    const slugs = [...new Set(tools.flatMap(t => t.workswith))]
    return slugs.map(slug => ({
        params: { tool: slug.toLowerCase() },
        props: { slug, tools: tools.filter(t => t.workswith.includes(slug)) },
    }))
}

const { slug, tools } = Astro.props
---

<Layout title={`CLI tools that work with ${slug}`}>
    <div class="page-header">
        <h1>CLI tools that work with <code>{slug}</code></h1>
    </div>

    <ul class="tool-list">
        {tools.map(tool => (
            <li class="tool-card">
                <h2><a href={`/tool/${tool.name}`}>{tool.name}</a></h2>
                <p class="description">{tool.description}</p>
                <div class="badges">
                    {tool.language && <a class="badge" href={`/language/${tool.language.toLowerCase()}`}>{tool.language}</a>}
                    {tool.workswith.map(w => (
                        <a class="badge" href={`/works-with/${w.toLowerCase()}`}>Works with {w}</a>
                    ))}
                </div>
            </li>
        ))}
    </ul>
</Layout>
