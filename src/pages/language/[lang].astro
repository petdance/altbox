---
import Layout from '../../layouts/Layout.astro'
import { getAllTools } from '../../lib/tools.js'

export function getStaticPaths() {
    const tools = getAllTools()
    const langs = [...new Set(tools.filter(t => t.language).map(t => t.language.toLowerCase()))]
    return langs.map(lang => ({
        params: { lang },
        props: {
            lang,
            displayName: tools.find(t => t.language && t.language.toLowerCase() === lang).language,
            tools: tools.filter(t => t.language && t.language.toLowerCase() === lang),
        },
    }))
}

const { lang, displayName, tools } = Astro.props
---

<Layout title={`${displayName} tools`}>
    <div class="page-header">
        <h1>Alternative tools written in {displayName}</h1>
    </div>

    <div class="tools-table">
        {tools.map(tool => (
            <div class="tool-card">
                <div class="tool-name">
                    <a href={`/tool/${tool.name.toLowerCase()}`}>{tool.name}</a>
                </div>
                <div class="tool-info">
                    <p class="description">{tool.description}</p>
                    <div class="badges">
                        {tool.alternativeto.map((alt, i) => (
                            <a href={`/alternative-to/${alt}`} class="badge">Alternative to {alt}</a>
                        ))}
                        {tool.workswith.map(work => (
                            <a href={`/works-with/${work.toLowerCase()}`} class="badge">Works with {work}</a>
                        ))}
                    </div>
                </div>
            </div>
        ))}
    </div>

    <style>
        .tools-table {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 1rem 2rem;
            margin: 2rem 0;
        }

        .tool-card {
            display: contents;
        }

        .tool-name {
            font-weight: bold;
        }

        .tool-name a {
            text-decoration: none;
            font-size: 1.1rem;
            font-family: var(--font-mono);
        }

        .tool-name a:hover {
            text-decoration: underline;
        }

        .tool-info .description {
            margin: 0 0 0.5rem 0;
            color: var(--muted);
            font-size: 0.9rem;
        }
    </style>
</Layout>
