---
import Layout from '../../layouts/Layout.astro'
import { getAllTools } from '../../lib/tools.js'

export function getStaticPaths() {
    const tools = getAllTools()
    const langs = [...new Set(tools.filter(t => t.language).map(t => t.language.toLowerCase()))]
    return langs.map(lang => ({
        params: { lang },
        props: {
            lang,
            displayName: tools.find(t => t.language && t.language.toLowerCase() === lang).language,
            tools: tools.filter(t => t.language && t.language.toLowerCase() === lang),
        },
    }))
}

const { lang, displayName, tools } = Astro.props
---

<Layout title={`${displayName} tools`}>
    <div class="page-header">
        <h1>Tools written in {displayName}</h1>
    </div>

    <ul class="tool-list">
        {tools.map(tool => (
            <li class="tool-card">
                <h2><a href={`/tool/${tool.name}`}>{tool.name}</a></h2>
                <p class="description">{tool.description}</p>
                <div class="badges">
                    {tool.alternativeto.map(alt => (
                        <a class="badge" href={`/alternative-to/${alt}`}>Alternative to {alt}</a>
                    ))}
                    {tool.workswith.map(w => (
                        <a class="badge" href={`/works-with/${w}`}>Works with {w}</a>
                    ))}
                </div>
            </li>
        ))}
    </ul>
</Layout>
