---
import Layout from '../../layouts/Layout.astro'
import { getAllTools } from '../../lib/tools.js'

export function getStaticPaths() {
    const tools = getAllTools()
    const licenses = [...new Set(tools.map(t => t.license.toLowerCase()))]
    return licenses.map(license => ({
        params: { license },
        props: {
            license,
            displayName: tools.find(t => t.license.toLowerCase() === license).license,
            tools: tools.filter(t => t.license.toLowerCase() === license),
        },
    }))
}

const { license, displayName, tools } = Astro.props
---

<Layout title={`${displayName}-licensed tools`}>
    <div class="page-header">
        <h1>{displayName}-licensed tools</h1>
    </div>

    <ul class="tool-list">
        {tools.map(tool => (
            <li class="tool-card">
                <h2><a href={`/tool/${tool.name}`}>{tool.name}</a></h2>
                <p class="description">{tool.description}</p>
                <div class="badges">
                    {tool.alternativeto.map(alt => (
                        <a class="badge" href={`/alternative-to/${alt}`}>alternative to {alt}</a>
                    ))}
                    <a class="badge" href={`/language/${tool.language.toLowerCase()}`}>{tool.language}</a>
                </div>
            </li>
        ))}
    </ul>
</Layout>
